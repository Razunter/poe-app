{
  "name": "poe-app-sveltekit",
  "version": "0.0.3",
  "browserslist": [
    "> 0.2%",
    "last 2 versions",
    "Firefox ESR",
    "not IE < 12",
    "not ie_mob < 12",
    "not dead"
  ],
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:start": "vite build & node -r dotenv/config build dotenv_config_path=./.env.local",
    "start": "node -r dotenv/config build dotenv_config_path=./.env.local",
    "package": "svelte-kit package",
    "preview": "vite preview",
    "test": "playwright test",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "types-sync": "svelte-kit sync"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@eslint/eslintrc": "^3.2.0",
    "@iconify/icons-mdi": "^1.2.48",
    "@iconify/svelte": "4.0.2",
    "@playwright/test": "^1.49.0",
    "@sveltejs/adapter-node": "^5.2.9",
    "@sveltejs/kit": "^2.8.2",
    "@sveltejs/vite-plugin-svelte": "^4.0.1",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "autoprefixer": "^10.4.20",
    "eslint": "9.15.0",
    "eslint-config-canonical": "^44.3.31",
    "eslint-plugin-depend": "^0.12.0",
    "eslint-plugin-svelte": "^2.46.0",
    "globals": "^15.12.0",
    "postcss": "^8.4.49",
    "postcss-load-config": "^6.0.1",
    "prettier-plugin-svelte": "^3.3.2",
    "sass": "^1.81.0",
    "svelte-check": "^4.1.0",
    "svelte-eslint-parser": "^0.43.0",
    "svelte-language-server": "^0.17.7",
    "tslib": "^2.8.1",
    "typescript": "^5.7.2",
    "typescript-svelte-plugin": "^0.3.43"
  },
  "type": "module",
  "dependencies": {
    "@sveltestrap/sveltestrap": "^6.2.7",
    "@twurple/api": "^7.2.0",
    "@twurple/auth": "^7.2.0",
    "axios": "^1.7.7",
    "bootstrap": "^5.3.3",
    "bootstrap-esm": "^1.0.0",
    "compare-versions": "^6.1.1",
    "dotenv": "^16.4.5",
    "just-intersect": "^4.3.0",
    "just-shuffle": "^4.2.0",
    "puppeteer": "^23.9.0",
    "svelecte": "^5.0.0-next.12",
    "svelte": "^5.2.7",
    "vite": "^5.4.11"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "@sveltejs/kit",
    "core-js-pure",
    "esbuild",
    "puppeteer",
    "svelte-preprocess"
  ]
}
