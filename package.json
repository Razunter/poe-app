{
  "name": "poe-app-sveltekit",
  "version": "0.0.3",
  "browserslist": [
    "> 0.2%",
    "last 2 versions",
    "Firefox ESR",
    "not IE < 12",
    "not ie_mob < 12",
    "not dead"
  ],
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:start": "vite build & node -r dotenv/config build dotenv_config_path=./.env.local",
    "start": "node -r dotenv/config build dotenv_config_path=./.env.local",
    "package": "svelte-kit package",
    "preview": "vite preview",
    "test": "playwright test",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "types-sync": "svelte-kit sync"
  },
  "devDependencies": {
    "@babel/core": "^7.26.9",
    "@babel/preset-env": "^7.26.9",
    "@eslint/eslintrc": "^3.2.0",
    "@iconify/icons-mdi": "^1.2.48",
    "@iconify/svelte": "4.2.0",
    "@playwright/test": "^1.50.1",
    "@sveltejs/adapter-node": "^5.2.12",
    "@sveltejs/kit": "^2.17.2",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@typescript-eslint/eslint-plugin": "^8.24.1",
    "@typescript-eslint/parser": "^8.24.1",
    "autoprefixer": "^10.4.20",
    "eslint": "9.20.1",
    "eslint-config-canonical": "^43.0.14",
    "eslint-plugin-depend": "^0.12.0",
    "eslint-plugin-svelte": "^2.46.1",
    "globals": "^15.15.0",
    "postcss": "^8.5.3",
    "postcss-load-config": "^6.0.1",
    "prettier-plugin-svelte": "^3.3.3",
    "sass": "1.77.8",
    "svelte-check": "^4.1.4",
    "svelte-language-server": "^0.17.10",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3",
    "typescript-svelte-plugin": "^0.3.45"
  },
  "type": "module",
  "dependencies": {
    "@sveltestrap/sveltestrap": "^6.2.7",
    "@twurple/api": "^7.2.1",
    "@twurple/auth": "^7.2.1",
    "axios": "^1.7.9",
    "bootstrap": "^5.3.3",
    "bootstrap-esm": "^1.0.0",
    "caniuse-lite": "^1.0.30001700",
    "compare-versions": "^6.1.1",
    "dotenv": "^16.4.7",
    "just-intersect": "^4.3.0",
    "just-shuffle": "^4.2.0",
    "puppeteer": "^24.2.1",
    "svelecte": "^5.1.4",
    "svelte": "^5.20.2",
    "vite": "^6.1.1"
  },
  "trustedDependencies": [
    "core-js-pure",
    "svelte-preprocess"
  ]
}
